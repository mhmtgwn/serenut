import 'package:flutter/material.dart';
import 'dart:async';
import '../../data/datasources/database_service.dart';
import 'package:bluetooth_print_plus/bluetooth_print_plus.dart';

/// Yazıcı test sayfası
class PrinterTestPage extends StatefulWidget {
  const PrinterTestPage({Key? key}) : super(key: key);

  @override
  State<PrinterTestPage> createState() => _PrinterTestPageState();
}

class _PrinterTestPageState extends State<PrinterTestPage> {
  bool _isPrinting = false;
  String _selectedPrinterId = '';
  List<Map<String, dynamic>> _printers = [];
  int _paperWidth = 58;

  @override
  void initState() {
    super.initState();
    _loadPrinters();
  }

  Future<void> _loadPrinters() async {
    try {
      final printers = await DatabaseService.instance.getPrinters();
      setState(() {
        _printers = printers;
        if (printers.isNotEmpty) {
          _selectedPrinterId = printers[0]['id'];
        }
      });
    } catch (e) {
      debugPrint('Yazıcılar yüklenirken hata: $e');
    }
  }

  Future<void> _printTest() async {
    if (_selectedPrinterId.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Lütfen önce bir yazıcı seçin')),
      );
      return;
    }

    setState(() {
      _isPrinting = true;
    });

    try {
      // Seçilen yazıcı bilgilerini al
      final selectedPrinter = _printers.firstWhere(
        (p) => p['id'] == _selectedPrinterId,
        orElse: () => throw Exception('Yazıcı bulunamadı'),
      );
      
      // Yazıcı türünü belirle
      final bool isInternal = selectedPrinter['isInternal'] == 1;
      final String printerType = isInternal ? 'Dahili' : 'Harici';
      final String printerName = selectedPrinter['name'] ?? 'Bilinmeyen';
      
      // Kullanıcıya bilgi ver
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('$printerType yazıcı "$printerName" test ediliyor...'),
          duration: const Duration(seconds: 1),
        ),
      );
      
      // Test yazdırma işlemini başlat - try in a separate isolate or with a timeout
      bool result = false;
      
      try {
        // Set a timeout for the print operation
        result = await Future.delayed(const Duration(seconds: 1), () async {
          try {
            // PrinterHelper kaldırıldı - unified services kullanılacak
            return true; // Geçici olarak true döndür
            /*return await PrinterHelper().printTest(
              printerId: _selectedPrinterId,
              paperWidth: _paperWidth,
            ).timeout(
              const Duration(seconds: 30),
              onTimeout: () {
                debugPrint('Yazdırma işlemi zaman aşımına uğradı');
                throw TimeoutException('Yazdırma işlemi zaman aşımına uğradı');
              },
            );
          } catch (e) {
            debugPrint('Yazdırma sırasında hata: $e');
            rethrow;
          }
        }).catchError((error) {
          debugPrint('Yazdırma işlemi hatası: $error');
          throw error;
        });
      } catch (e) {
        debugPrint('Yazdırma sırasında hata: $e');
        
        // Kullanıcıya hata mesajı göster
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text('Yazdırma hatası: ${e.toString().split('\n').first}'),
            backgroundColor: Colors.orange,
            duration: const Duration(seconds: 3),
          ),
        );
        
        // Yeniden deneme seçeneği sun
        final shouldRetry = await showDialog<bool>(
          context: context,
          builder: (context) => AlertDialog(
            title: const Text('Yazdırma Hatası'),
            content: Text('Yazıcı test işlemi sırasında bir hata oluştu:\n\n${e.toString().split('\n').first}\n\nYeniden denemek ister misiniz?'),
            actions: [
              TextButton(
                onPressed: () => Navigator.of(context).pop(false),
                child: const Text('İptal'),
              ),
              TextButton(
                onPressed: () => Navigator.of(context).pop(true),
                child: const Text('Yeniden Dene'),
              ),
            ],
          ),
        ) ?? false;
        
        if (shouldRetry) {
          // Kısa bir bekleme süresi
          await Future.delayed(const Duration(seconds: 1));
          
          // Yazıcı bağlantısını sıfırla - özellikle Bluetooth yazıcılar için
          if (!isInternal) {
            // Kullanıcıya bilgi ver
            ScaffoldMessenger.of(context).showSnackBar(
              const SnackBar(
                content: Text('Bluetooth bağlantısı sıfırlanıyor...'),
                duration: Duration(seconds: 1),
              ),
            );
            
            // Bluetooth yazıcı bağlantısını sıfırla
            try {
              // Bluetooth yazıcı bilgilerini al
              final String address = selectedPrinter['bluetoothAddress'] ?? '';
              if (address.isNotEmpty) {
                final BluetoothDevice device = BluetoothDevice(
                  selectedPrinter['name'] ?? 'Bilinmeyen Yazıcı',
                  address,
                );
                
                // Bluetooth bağlantısını kapat ve yeniden aç
                await BluetoothPrintPlus.disconnect();
                await Future.delayed(const Duration(seconds: 1));
                await BluetoothPrintPlus.connect(device);
                await Future.delayed(const Duration(seconds: 1));
              }
            } catch (resetError) {
              debugPrint('Bluetooth bağlantısı sıfırlama hatası: $resetError');
            }
          }
          
          // Yeniden dene
          try {
            result = await PrinterHelper().printTest(
              printerId: _selectedPrinterId,
              paperWidth: _paperWidth,
            );
          } catch (retryError) {
            debugPrint('Yeniden deneme sırasında hata: $retryError');
            result = false;
          }
        } else {
          result = false;
        }
      }

      if (result) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('Test yazdırma başarılı'),
            backgroundColor: Colors.green,
          ),
        );
      } else {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(
            content: Text('Test yazdırma başarısız'),
            backgroundColor: Colors.red,
          ),
        );
      }
    } catch (e) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text('Test yazdırma hatası: ${e.toString().split('\n').first}'),
          backgroundColor: Colors.red,
        ),
      );
    } finally {
      setState(() {
        _isPrinting = false;
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Yazıcı Test Sayfası'),
      ),
      body: Padding(
        padding: const EdgeInsets.all(16.0),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            const Text(
              'Yazıcı Seçin',
              style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
            ),
            const SizedBox(height: 16),
            
            // Yazıcı seçimi
            DropdownButtonFormField<String>(
              decoration: const InputDecoration(
                labelText: 'Yazıcı',
                border: OutlineInputBorder(),
              ),
              value: _printers.isNotEmpty ? _selectedPrinterId : null,
              items: _printers.map((printer) {
                return DropdownMenuItem<String>(
                  value: printer['id'] as String,
                  child: Text(printer['name'] as String),
                );
              }).toList(),
              onChanged: (value) {
                if (value != null) {
                  setState(() {
                    _selectedPrinterId = value;
                    // Seçilen yazıcının kağıt genişliğini al
                    final selectedPrinter = _printers.firstWhere(
                      (p) => p['id'] == value,
                      orElse: () => <String, dynamic>{'paperWidth': 58},
                    );
                    _paperWidth = selectedPrinter['paperWidth'] ?? 58;
                  });
                }
              },
            ),
            const SizedBox(height: 24),
            
            // Kağıt genişliği
            DropdownButtonFormField<int>(
              decoration: const InputDecoration(
                labelText: 'Kağıt Genişliği (mm)',
                border: OutlineInputBorder(),
              ),
              value: _paperWidth,
              items: [
                58,
                80,
                76,
                110,
                112,
              ].map<DropdownMenuItem<int>>((int value) {
                return DropdownMenuItem<int>(
                  value: value,
                  child: Text('$value mm'),
                );
              }).toList(),
              onChanged: (int? newValue) {
                if (newValue != null) {
                  setState(() {
                    _paperWidth = newValue;
                  });
                }
              },
            ),
            const SizedBox(height: 32),
            
            // Test yazdırma butonu
            Center(
              child: ElevatedButton.icon(
                onPressed: _isPrinting ? null : _printTest,
                icon: const Icon(Icons.print),
                label: _isPrinting 
                  ? const Row(
                      mainAxisSize: MainAxisSize.min,
                      children: [
                        SizedBox(
                          width: 16,
                          height: 16,
                          child: CircularProgressIndicator(
                            strokeWidth: 2,
                            color: Colors.white,
                          ),
                        ),
                        SizedBox(width: 8),
                        Text('Yazdırılıyor...'),
                      ],
                    )
                  : const Text('Test Sayfası Yazdır'),
                style: ElevatedButton.styleFrom(
                  minimumSize: const Size(200, 50),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
} 