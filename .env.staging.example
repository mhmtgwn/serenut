# Serenut OS - Staging VPS Environment Secrets
# IMPORTANT: Bu dosyanın kopyasını .env.staging olarak oluşturun ve gerçek bilgileri girin.
# Kesinlikle Git'e veya raporlara (walkthrough vb.) commitlemeyin.

STAGING_API_BASE_URL=https://staging-api.serenut.com
TEST_USER_EMAIL=test_runner@serenut.com
TEST_USER_PASSWORD=your_secure_password_here
TEST_COMPANY_ID=test_tenant_01
TEST_BRANCH_ID=test_branch_01

# Audit ve Test Okumaları için (Write yetkisi olmayan Audit kullanıcısı önerilir)
STAGING_DATABASE_HOST=db.staging.serenut.com
STAGING_DATABASE_PORT=5432
STAGING_DATABASE_NAME=serenut_db_staging
STAGING_DATABASE_USER=serenut_audit_reader
STAGING_DATABASE_PASSWORD=audit_db_password_here

# Redis
STAGING_REDIS_URL=redis://redis.staging.serenut.com:6379/1
