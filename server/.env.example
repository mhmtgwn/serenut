# Serenut OS — Server Environment Variables
# Bu dosya şablondur. Gerçek değerler .env.production dosyasında olmalı.
# .env.production asla Git'e commit edilmemeli.
#
# Güçlü sır üretmek için:
#   openssl rand -hex 64   → JWT_SECRET için
#   openssl rand -hex 32   → diğer sırlar için

# ── SUNUCU ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
PUBLIC_URL=https://serenut.com
LEGAL_DOCUMENT_VERSION=2026-07

# ── VERİTABANI ────────────────────────────────────────────────────────────────
# UYARI: Varsayılan şifre kullanmayın. Güçlü bir şifre oluşturun.
DATABASE_URL=postgresql://serenut_user:STRONG_DB_PASSWORD_HERE@127.0.0.1:5432/serenut_db
POSTGRES_USER=serenut_user
POSTGRES_PASSWORD=STRONG_DB_PASSWORD_HERE
POSTGRES_DB=serenut_db

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:STRONG_REDIS_PASSWORD_HERE@127.0.0.1:6379
REDIS_PASSWORD=STRONG_REDIS_PASSWORD_HERE

# ── JWT / KİMLİK DOĞRULAMA ───────────────────────────────────────────────────
# ZORUNLU: En az 32 karakter. Üretim için 64 hex karakter önerilir.
# Eksik veya kısa olması durumunda sunucu BAŞLAMAZ.
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_64_OUTPUT

# ── LİSANS İMZALAMA / RSA KEY PAIR ──────────────────────────────────────────
# ZORUNLU: Lisans imzalama için 2048-bit RSA Private Key (Sunucuda bulunur)
# Format: Tek satır PEM veya JSON JWK formatında string
RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── YEDEKLEME ─────────────────────────────────────────────────────────────────
BACKUP_PASSPHRASE=STRONG_BACKUP_ENCRYPTION_PASSWORD
S3_BUCKET=serenut-backups
S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
DB_HOST=127.0.0.1
DB_USER=serenut_user
DB_NAME=serenut_db

# ── E-POSTA (VPS SMTP; Postmark API anahtarı isteğe bağlı yedek) ─────────────
SMTP_HOST=mail.serenut.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@serenut.com
SMTP_PASSWORD=STRONG_SMTP_PASSWORD_HERE
SMTP_FROM_EMAIL=noreply@serenut.com
SMTP_FROM_NAME=Serenut
# SMTP_API_KEY=YOUR_POSTMARK_API_KEY

# ── SMS (Netgsm / Twilio) ─────────────────────────────────────────────────────
SMS_PROVIDER=netgsm
SMS_API_KEY=YOUR_NETGSM_API_KEY
SMS_API_SECRET=YOUR_NETGSM_API_SECRET
SMS_SENDER_ID=SERENUT

# ── ÖDEME GEÇİDİ (İyzico) ───────────────────────────────────────────────────
IYZICO_ENABLED=false

# ── ÖDEME GEÇİDİ (Stripe — alternatif) ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
